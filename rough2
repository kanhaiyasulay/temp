const { app, BrowserWindow, session } = require("electron");
const path = require("path");

function createWindow() {
  const win = new BrowserWindow({
    width: 1280,
    height: 800,
    webPreferences: {
      nodeIntegration: false,
      contextIsolation: true,
    },
  });

  // Load the React dev server
  win.loadURL("http://localhost:3000");

  // Open DevTools in development (remove for production)
  win.webContents.openDevTools();
}

// ── Microphone permission handling ──────────────────────────────────
// Automatically grant microphone (and camera) permission requests
// so WebRTC / MediaDevices.getUserMedia works inside Electron.
app.whenReady().then(() => {
  session.defaultSession.setPermissionRequestHandler(
    (_webContents, permission, callback) => {
      const allowed = ["media", "mediaKeySystem", "geolocation"];
      callback(allowed.includes(permission));
    }
  );

  // Also handle permission-check queries (Chromium 97+)
  session.defaultSession.setPermissionCheckHandler(
    (_webContents, permission) => {
      const allowed = ["media", "mediaKeySystem"];
      return allowed.includes(permission);
    }
  );

  createWindow();

  app.on("activate", () => {
    // macOS: re-create window when dock icon clicked and no windows open
    if (BrowserWindow.getAllWindows().length === 0) createWindow();
  });
});

app.on("window-all-closed", () => {
  if (process.platform !== "darwin") app.quit();
});
